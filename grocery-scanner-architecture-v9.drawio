        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- MATCHING + EXCEL NOTES                                  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="match-note" value="Matching logic (step ⑤):&#xa;• matched  — amount exact + date ±2 days → matched_receipt_id set&#xa;• partial   — receipt found on date but amount differs → diff_amount stored&#xa;• unmatched — no receipt found within ±2 days at any amount" style="text;html=1;strokeColor=#6C3CE1;fillColor=#F0EBFF;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#4a2fa0;" vertex="1" parent="1">
          <mxGeometry x="40" y="818" width="460" height="70" as="geometry" />
        </mxCell>
        <mxCell id="excel-note" value="starling-reconciliation.xlsx (step ⑦):&#xa;Columns: Month | Date | Shop | Starling £ | Receipt £ | Diff | Status | Receipt ID&#xa;• One row per Starling transaction&#xa;• Overwritten for the synced month on each sync&#xa;• Separate file from master.xlsx in same S3 exports bucket" style="text;html=1;strokeColor=#6C3CE1;fillColor=#F0EBFF;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#4a2fa0;" vertex="1" parent="1">
          <mxGeometry x="520" y="818" width="500" height="70" as="geometry" />
        </mxCell>
        <mxCell id="setup-note" value="One-time setup:&#xa;1. Get PAT from developer.starlingbank.com (scopes: account:read, transaction:read)&#xa;2. aws ssm put-parameter --name /grocery-scanner/{env}/starling-token --value TOKEN --type SecureString&#xa;3. Call GET /api/v2/accounts to find Groceries Space UID&#xa;4. aws ssm put-parameter --name /grocery-scanner/{env}/starling-space-uid --value UID --type SecureString" style="text;html=1;strokeColor=#6C3CE1;fillColor=#F0EBFF;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#4a2fa0;" vertex="1" parent="1">
          <mxGeometry x="1040" y="818" width="500" height="70" as="geometry" />
        </mxCell>

      </root>
