        <!-- Notes row -->
        <mxCell id="v10-match-note" value="Matching logic (step ⑦):&#xa;• matched      — email + Starling: same amount, date ±3 days&#xa;• linked        — PayPal + eBay email: same amount, date ±3 days (known pair)&#xa;• needs_review — ambiguous: multiple candidates or amount mismatch&#xa;• unmatched    — email only (paid by card/cash) or Starling only (no email)" style="text;html=1;strokeColor=#1B6CA8;fillColor=#E8F4FD;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#1B6CA8;" vertex="1" parent="1">
          <mxGeometry x="40" y="1244" width="500" height="84" as="geometry" />
        </mxCell>
        <mxCell id="v10-excel-note" value="finance.xlsx (step ⑧):&#xa;Columns: Date | Store | Category | Item Type | Amount (GBP) | Payment Method | Source | Status | Transaction ID&#xa;• One row per logical transaction&#xa;• Regenerated after every sync AND after every manual edit&#xa;• Entirely separate from master.xlsx and starling-reconciliation.xlsx" style="text;html=1;strokeColor=#1B6CA8;fillColor=#E8F4FD;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#1B6CA8;" vertex="1" parent="1">
          <mxGeometry x="558" y="1244" width="520" height="84" as="geometry" />
        </mxCell>
        <mxCell id="v10-setup-note" value="One-time setup (Finance v10):&#xa;1. Create OAuth credentials at console.cloud.google.com&#xa;2. Obtain refresh token, store in SSM: gmail-refresh-token, gmail-client-id, gmail-client-secret&#xa;3. Create new Starling pot for online spending&#xa;4. Store pot UID in SSM: starling-finance-space-uid&#xa;5. Create OpenAI account, store key in SSM: openai-api-key" style="text;html=1;strokeColor=#1B6CA8;fillColor=#E8F4FD;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#1B6CA8;" vertex="1" parent="1">
          <mxGeometry x="1096" y="1244" width="480" height="84" as="geometry" />
