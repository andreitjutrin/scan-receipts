        </mxCell>
        <mxCell id="db_item_types" parent="1" style="rounded=1;fillColor=#ad1457;strokeColor=#880e4f;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🗄️ grocery-item-types (CURATED — owned by you)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;PK: item_type_id (text)&#xa;category_id: FK → grocery-categories&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;item_type_id      category_id&#xa;yoghurt           dairy-eggs&#xa;butter            dairy-eggs&#xa;smoked salmon     fish-seafood&#xa;bread             bakery&#xa;muffin            snacks&#xa;suckies           dairy-eggs&#xa;halloumi          dairy-eggs&#xa;(you build this list — add new types as you scan)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;RETROACTIVE UPDATES: category never stored on&#xa;grocery-items rows. Always derived here at query&#xa;time. Edit category_id here → instant effect&#xa;on all historical receipts. Zero DynamoDB writes." vertex="1">
