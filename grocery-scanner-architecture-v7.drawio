        <mxCell id="pwa_mapping_mgmt" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="📋 Mapping Management screen&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;View all item_type → category mappings&#xa;Edit: change yoghurt → dairy to → breakfast&#xa;  ALL past items with item_type=yoghurt&#xa;  now appear as breakfast automatically&#xa;Create new item_type (e.g. halloumi)&#xa;Create new category&#xa;Assign item_type to category" vertex="1">
