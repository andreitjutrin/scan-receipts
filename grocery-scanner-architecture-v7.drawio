        <mxCell id="lam_u2" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;" value="Step 2: Build S3 key (file path)&#xa;receipts/2026/03/01/a3f9.jpg" vertex="1">
