        <mxCell id="lam_mapping" parent="1" style="rounded=1;fillColor=#8e24aa;strokeColor=#4a148c;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="⚡ reference Lambda (extended)&#xa;GET /item-types → list all item types&#xa;POST /item-types → create new item_type&#xa;PUT /item-types/{id} → update category&#xa;  No batch update needed: category always&#xa;  derived from ItemTypes at query time" vertex="1">
