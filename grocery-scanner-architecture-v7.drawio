          <mxGeometry height="36" width="264" x="560" y="534" as="geometry" />
        </mxCell>
        <mxCell id="lam_u5" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;" value="Step 5: Return {receipt_id, presigned_url}&#xa;back to PWA — PWA now knows where to upload" vertex="1">
          <mxGeometry height="36" width="264" x="560" y="576" as="geometry" />
        </mxCell>
        <mxCell id="db_receipts" parent="1" style="rounded=1;fillColor=#ad1457;strokeColor=#880e4f;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🗄️ grocery-receipts — NEW RECORD&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;receipt_id : a3f9c2d1-8b4e...  (UUID, unique forever)&#xa;s3_key     : receipts/2026/03/01/a3f9.jpg&#xa;store_id   : tesco  (user selected before scanning)&#xa;status     : pending&#xa;user_id    : default&#xa;receipt_date: 2026-03-01  (today, updated after Textract)&#xa;total_amount: null  (filled in after Textract)&#xa;item_count : 0  (filled in after processing)&#xa;needs_review_count: 0  (filled in after processing)&#xa;process_count: 0  (safety: max 3 reprocesses allowed)&#xa;created_at : 2026-03-01T10:32:00Z" vertex="1">
          <mxGeometry height="210" width="338" x="1153" y="372" as="geometry" />
        </mxCell>
        <mxCell id="pwa_upload_direct" parent="1" style="rounded=1;fillColor=#1565c0;strokeColor=#0d47a1;fontColor=#fff;fontSize=10;" value="1e. PWA receives {receipt_id, presigned_url}&#xa;Uses presigned_url to upload compressed&#xa;image DIRECTLY to S3&#xa;Lambda is NOT involved in this step" vertex="1">
          <mxGeometry height="66" width="230" x="35" y="466" as="geometry" />
        </mxCell>
        <mxCell id="s3_images" parent="1" style="rounded=1;fillColor=#2e7d32;strokeColor=#1b5e20;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🪣 S3: grocery-images&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Path: receipts/2026/03/01/a3f9.jpg&#xa;Size: ~400KB (compressed by PWA on device)&#xa;Original 2–4MB photo never uploaded&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Auto-delete: after 365 days&#xa;(image only needed for reprocessing)&#xa;Cost: ~£0.001/month at 100 receipts" vertex="1">
          <mxGeometry height="170" width="234" x="873" y="430" as="geometry" />
        </mxCell>
        <mxCell id="pwa_spinner" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;" value="1f. PWA shows &#39;Processing...&#39; spinner&#xa;S3 event triggers processor automatically&#xa;PWA polls every 2s for status change" vertex="1">
          <mxGeometry height="56" width="230" x="35" y="550" as="geometry" />
        </mxCell>
        <mxCell id="s2_bar" parent="1" style="text;html=1;strokeColor=#4a148c;fillColor=#e1bee7;align=left;fontSize=11;fontStyle=1;fontColor=#4a148c;rounded=1;spacingLeft=8;" value="② PROCESS — S3 event fires automatically when photo lands. No manual trigger. Lambda runs Textract, parses result, discards lines after total." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="634" as="geometry" />
        </mxCell>
        <mxCell id="s3_event_note" parent="1" style="rounded=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;fontStyle=2;" value="☁️ S3 Event Notification&#xa;Fires automatically the moment&#xa;photo file lands in S3 bucket&#xa;No manual trigger needed" vertex="1">
          <mxGeometry height="66" width="234" x="873" y="672" as="geometry" />
        </mxCell>
        <mxCell id="lam_cost_check" parent="1" style="rounded=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;align=left;spacingLeft=6;" value="⚡ processor Lambda — Step 1: Safety checks&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Check process_count on receipt&#xa;If process_count ≥ 3 → set status=failed&#xa;   log &#39;max reprocess limit reached&#39;&#xa;   send alert email → STOP&#xa;Otherwise → increment process_count&#xa;Set status = processing" vertex="1">
          <mxGeometry height="110" width="278" x="553" y="668" as="geometry" />
        </mxCell>
        <mxCell id="db_status_proc" parent="1" style="rounded=1;fillColor=#ad1457;strokeColor=#880e4f;fontColor=#fff;fontSize=10;" value="🗄️ grocery-receipts UPDATED&#xa;status: processing&#xa;process_count: incremented" vertex="1">
          <mxGeometry height="56" width="338" x="1153" y="672" as="geometry" />
        </mxCell>
        <mxCell id="lam_textract_step" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;" value="Step 2: Call Textract AnalyzeExpense&#xa;Pass S3 bucket + key&#xa;Wait for response (5–30 seconds)&#xa;Raw JSON kept IN MEMORY ONLY&#xa;Never written to disk or database" vertex="1">
          <mxGeometry height="72" width="278" x="553" y="792" as="geometry" />
        </mxCell>
        <mxCell id="textract_box" parent="1" style="rounded=1;fillColor=#2e7d32;strokeColor=#1b5e20;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🔍 AWS Textract AnalyzeExpense&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Detects receipt area automatically&#xa;Ignores: background, table surface,&#xa;hands, shadows, surrounding objects&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Returns in memory (not stored):&#xa;• Store name from header&#xa;• Receipt date&#xa;• Line items with prices&#xa;• TOTAL field&#xa;Cost: ~£0.012 per receipt" vertex="1">
          <mxGeometry height="200" width="234" x="873" y="756" as="geometry" />
        </mxCell>
        <mxCell id="lam_parse" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;align=left;spacingLeft=6;" value="Step 3: Parse Textract response&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Extract: date, total, line items&#xa;Strip brand prefixes (e.g. &#39;Tesco Finest&#39;)&#xa;Normalise: lowercase, remove weight/size&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;DISCARD AFTER TOTAL LINE:&#xa;All lines after TOTAL are ignored:&#xa;• Credit card type / last 4 digits&#xa;• Points earned / Clubcard savings&#xa;• VAT summary / cashback lines&#xa;These are never written to any table" vertex="1">
          <mxGeometry height="160" width="278" x="553" y="880" as="geometry" />
        </mxCell>
        <mxCell id="s3_bar" parent="1" style="text;html=1;strokeColor=#1b5e20;fillColor=#c8e6c9;align=left;fontSize=11;fontStyle=1;fontColor=#1b5e20;rounded=1;spacingLeft=8;" value="③ HYBRID CATEGORY MATCHING — 3 layers per item. Layer 1: store exact match. Layer 2: fuzzy against 600 in-memory keywords. Layer 3: unknown → user review. On any hit, writes to Layer 1 for next receipt." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="1062" as="geometry" />
        </mxCell>
        <mxCell id="threshold_legend" parent="1" style="rounded=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=10;align=left;spacingLeft=6;" value="📊 CONFIDENCE THRESHOLDS&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;≥ 92%  → auto-categorise silently. No review. Covers OCR noise (0→O, 1→I, rn→m).&#xa;75–91% → auto-categorise BUT flag for review. After user confirms 3× → promoted to trusted, no more prompts.&#xa;50–74% → always flag for review. Category shown as best guess, clearly marked uncertain.&#xa;&lt; 50%  → shown as Unknown. User picks category from scratch. No guess made." vertex="1">
          <mxGeometry height="110" width="620" x="873" y="1266" as="geometry" />
        </mxCell>
        <mxCell id="l1_bg" parent="1" style="rounded=1;fillColor=#f3e5f5;strokeColor=#8e24aa;" value="" vertex="1">
          <mxGeometry height="116" width="278" x="553" y="1266" as="geometry" />
        </mxCell>
        <mxCell id="l1_ttl" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=1;fontColor=#4a148c;" value="Layer 1: Store-Scoped Exact Match" vertex="1">
          <mxGeometry height="20" width="272" x="556" y="1272" as="geometry" />
        </mxCell>
        <mxCell id="l1_det" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;" value="DynamoDB get_item: tesco#normalised_name&#xa;Returns: item_type_id (NOT category directly)&#xa;Category = ItemTypes table lookup (2nd hop)&#xa;HIT → item_type resolved, confidence = 1.0&#xa;MISS → proceed to Layer 2" vertex="1">
          <mxGeometry height="82" width="266" x="558" y="1294" as="geometry" />
        </mxCell>
<mxCell id="l3_bg" parent="1" style="rounded=1;fillColor=#f3e5f5;strokeColor=#8e24aa;" value="" vertex="1">
          <mxGeometry height="148" width="278" x="553" y="1530" as="geometry" />
        </mxCell>
        <mxCell id="l3_ttl" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=1;fontColor=#4a148c;" value="Layer 2: In-Memory Fuzzy Match (RapidFuzz)" vertex="1">
          <mxGeometry height="20" width="272" x="556" y="1536" as="geometry" />
        </mxCell>
        <mxCell id="l3_det" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;" value="600 keywords loaded at cold start (~50KB)&#xa;token_sort_ratio scan, &lt;5ms for full list&#xa;Handles OCR noise: 0→O, 1→I, rn→m&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;score ≥ 92% → silent, write confident mapping&#xa;score 75–91% → auto + flag review, write tentative&#xa;score 50–74% → flag review, best-guess only&#xa;score &lt; 50% → Layer 3 (Unknown)" vertex="1">
          <mxGeometry height="114" width="266" x="558" y="1558" as="geometry" />
        </mxCell>
        <mxCell id="l4_bg" parent="1" style="rounded=1;fillColor=#ffcdd2;strokeColor=#e53935;" value="" vertex="1">
          <mxGeometry height="90" width="278" x="553" y="1694" as="geometry" />
        </mxCell>
        <mxCell id="l4_ttl" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=1;fontColor=#b71c1c;" value="Layer 3: Unknown — Manual Required" vertex="1">
          <mxGeometry height="20" width="272" x="556" y="1700" as="geometry" />
        </mxCell>
        <mxCell id="l4_det" parent="1" style="rounded=1;fillColor=#ffcdd2;strokeColor=#e53935;fontSize=10;" value="Nothing matched above 50%&#xa;item_type = Unknown, shown in PWA&#xa;needs_review = true, no guess made&#xa;User selects category from full list" vertex="1">
          <mxGeometry height="56" width="266" x="558" y="1722" as="geometry" />
        </mxCell>
        <mxCell id="db_mappings" parent="1" style="rounded=1;fillColor=#ad1457;strokeColor=#880e4f;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🗄️ grocery-mappings — ONE TABLE, ALL STORES&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;PK: mapping_key = store_id#normalised_name&#xa;GSI: store_id  (load all for a store at cold start)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;EXAMPLE ROWS (same product, different OCR reads):&#xa;mapping_key                  store    normalised_name       category      conf  count  trust      source&#xa;global#smoked salmon         global   smoked salmon         fish-seafood  1.00   10    trusted    seed&#xa;tesco#smoked salmon          tesco    smoked salmon         fish-seafood  0.95    7    trusted    global_exact&#xa;tesco#tesco tstd smkd slmn   tesco    tesco tstd smkd slmn  fish-seafood  0.95    4    confident  store_exact&#xa;tesco#smkd slmn              tesco    smkd slmn             fish-seafood  0.82    1    tentative  fuzzy&#xa;tesco#sm0ked salm0n          tesco    sm0ked salm0n         fish-seafood  0.88    2    confident  fuzzy&#xa;aldi#lachs 200g              aldi     lachs 200g            fish-seafood  0.76    1    tentative  fuzzy&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Trust promotion: tentative →(confirmed 3×)→ confident →(confirmed 5×)→ trusted&#xa;Trusted = never overwritten silently. Conflict flagged to user." vertex="1">
          <mxGeometry height="320" width="644" x="1153" y="1398" as="geometry" />
        </mxCell>
        <mxCell id="lam_save" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;" value="Step 4: Save all items to grocery-items&#xa;Step 5: Update grocery-receipts:&#xa;  status = completed or needs_review&#xa;  item_count, needs_review_count&#xa;  receipt_date (from Textract)&#xa;  total_amount (from Textract)" vertex="1">
          <mxGeometry height="96" width="278" x="553" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="db_items" parent="1" style="rounded=1;fillColor=#ad1457;strokeColor=#880e4f;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🗄️ grocery-items — ONE TABLE, ALL RECEIPTS&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;PK: receipt_id  SK: item_seq&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;receipt_id      : a3f9...  (links to receipts table)&#xa;item_seq        : 001, 002, 003...  (row order on receipt)&#xa;raw_name        : TESCO TSTD SMKD SLMN 200G  (exact Textract output)&#xa;normalised_name : smoked salmon  (cleaned for matching)&#xa;category        : fish-seafood&#xa;price           : 3.50&#xa;confidence      : 0.97  (matching confidence 0.0–1.0)&#xa;match_source    : store_exact | global_exact | fuzzy | manual&#xa;trust           : tentative | confident | trusted&#xa;needs_review    : false  (true if confidence &lt; 92% until confirmed)&#xa;confirmed       : false  (true once user has reviewed and accepted/corrected)" vertex="1">
          <mxGeometry height="220" width="644" x="1153" y="1766" as="geometry" />
        </mxCell>
        <mxCell id="s4_bar" parent="1" style="text;html=1;strokeColor=#006064;fillColor=#b2ebf2;align=left;fontSize=11;fontStyle=1;fontColor=#006064;rounded=1;spacingLeft=8;" value="④ AUTO ANALYTICS UPDATE — Backup Excel first, then append new rows. Power BI reads S3 and auto-refreshes." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="2016" as="geometry" />
        </mxCell>
        <mxCell id="lam_excel" parent="1" style="rounded=1;fillColor=#e1bee7;strokeColor=#8e24aa;fontSize=10;align=left;spacingLeft=6;" value="Step 6 (same processor Lambda):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;6a. Read master.xlsx from S3&#xa;6b. Create dated backup FIRST:&#xa;    master_backup_2026-03-01.xlsx&#xa;6c. Append new rows to master.xlsx&#xa;    (one row per line item: date, store,&#xa;    item, category, price)&#xa;6d. Write updated master.xlsx to S3&#xa;If 6d fails → backup already safe" vertex="1">
          <mxGeometry height="146" width="278" x="553" y="2052" as="geometry" />
        </mxCell>
        <mxCell id="s3_excel" parent="1" style="rounded=1;fillColor=#2e7d32;strokeColor=#1b5e20;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🪣 S3: grocery-exports&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;master.xlsx  (always current)&#xa;master_backup_2026-03-01.xlsx  (auto-created)&#xa;master_backup_2026-02-28.xlsx  (previous day)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;S3 Versioning ON: every write keeps prev version&#xa;Backup copies kept 30 days then auto-deleted&#xa;Restore: PWA Admin → Restore Backup&#xa;          or AWS Console → S3 → Versions" vertex="1">
          <mxGeometry height="180" width="234" x="873" y="2052" as="geometry" />
        </mxCell>
        <mxCell id="powerbi" parent="1" style="rounded=1;fillColor=#0078d4;strokeColor=#005a9e;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="📊 Power BI Desktop&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Connected directly to S3 URL&#xa;of master.xlsx&#xa;Auto-refresh: hourly schedule&#xa;Charts update automatically&#xa;No manual export or download needed" vertex="1">
          <mxGeometry height="130" width="250" x="1535" y="2052" as="geometry" />
        </mxCell>
        <mxCell id="pwa_poll" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;" value="PWA polls GET /receipts/{id}&#xa;every 2 seconds until&#xa;status = completed or needs_review&#xa;Then shows receipt result screen" vertex="1">
          <mxGeometry height="66" width="230" x="35" y="2052" as="geometry" />
        </mxCell>
        <mxCell id="api_poll" parent="1" style="rounded=1;fillColor=#f9a825;strokeColor=#e65100;fontSize=11;" value="GET /receipts/{receipt_id}" vertex="1">
          <mxGeometry height="40" width="200" x="315" y="2070" as="geometry" />
        </mxCell>
        <mxCell id="s5_bar" parent="1" style="text;html=1;strokeColor=#e65100;fillColor=#ffe082;align=left;fontSize=11;fontStyle=1;fontColor=#e65100;rounded=1;spacingLeft=8;" value="⑤ REVIEW &amp; CORRECT — User fixes flagged items per receipt. Corrections saved as trusted immediately." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="2266" as="geometry" />
        </mxCell>
        <mxCell id="pwa_receipt_list" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;" value="Receipt list screen&#xa;Badge shows needs_review count&#xa;e.g. &#39;Tesco 01/03 — 3 to review&#39;" vertex="1">
          <mxGeometry height="56" width="230" x="35" y="2310" as="geometry" />
        </mxCell>
        <mxCell id="api_get_receipt" parent="1" style="rounded=1;fillColor=#f9a825;strokeColor=#e65100;fontSize=11;" value="GET /receipts/{id}&#xa;returns receipt + all items" vertex="1">
          <mxGeometry height="46" width="200" x="315" y="2318" as="geometry" />
        </mxCell>
        <mxCell id="lam_get" parent="1" style="rounded=1;fillColor=#8e24aa;strokeColor=#4a148c;fontColor=#fff;fontSize=10;" value="⚡ receipts Lambda&#xa;Returns receipt header + all items&#xa;Flagged items marked needs_review=true" vertex="1">
          <mxGeometry height="56" width="278" x="553" y="2310" as="geometry" />
        </mxCell>
        <mxCell id="pwa_fix" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;" value="📸 Scanned receipt image shown alongside&#xa;Flagged items highlighted orange&#xa;Taps item → picks item_type from curated list&#xa;(yoghurt, butter, smoked salmon...)&#xa;item_type → category resolved automatically" vertex="1">
          <mxGeometry height="66" width="230" x="35" y="2386" as="geometry" />
        </mxCell>
        <mxCell id="api_confirm" parent="1" style="rounded=1;fillColor=#f9a825;strokeColor=#e65100;fontSize=11;" value="POST /receipts/{id}/confirm&#xa;{item_seq, new_category}" vertex="1">
          <mxGeometry height="46" width="200" x="315" y="2396" as="geometry" />
        </mxCell>
        <mxCell id="lam_correct" parent="1" style="rounded=1;fillColor=#8e24aa;strokeColor=#4a148c;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="⚡ receipts Lambda — save correction&#xa;1. Update item_type_id in grocery-items&#xa;   Category derived from ItemTypes at query time&#xa;2. Write to grocery-mappings:&#xa;   key: tesco#normalised_name → item_type_id&#xa;   trust: trusted  (manual = instant trust)&#xa;   source: manual, confidence: 1.0&#xa;3. Decrement receipt needs_review_count" vertex="1">
          <mxGeometry height="130" width="278" x="553" y="2380" as="geometry" />
        </mxCell>
        <mxCell id="s6_bar" parent="1" style="text;html=1;strokeColor=#bf360c;fillColor=#ffccbc;align=left;fontSize=11;fontStyle=1;fontColor=#bf360c;rounded=1;spacingLeft=8;" value="⑥ REPROCESS — Rerun Textract on same S3 image. Max 3 attempts enforced in Lambda to prevent cost loops." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="2570" as="geometry" />
        </mxCell>
        <mxCell id="pwa_reprocess" parent="1" style="rounded=1;fillColor=#e53935;strokeColor=#b71c1c;fontColor=#fff;fontSize=10;" value="User taps &#39;Reprocess Receipt&#39;&#xa;Shown when status=failed&#xa;or user requests manually" vertex="1">
          <mxGeometry height="56" width="230" x="35" y="2614" as="geometry" />
        </mxCell>
        <mxCell id="api_reprocess" parent="1" style="rounded=1;fillColor=#f9a825;strokeColor=#e65100;fontSize=11;" value="POST /receipts/{id}/reprocess" vertex="1">
          <mxGeometry height="40" width="200" x="315" y="2622" as="geometry" />
        </mxCell>
        <mxCell id="lam_reprocess" parent="1" style="rounded=1;fillColor=#8e24aa;strokeColor=#4a148c;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="⚡ processor Lambda (reprocess mode)&#xa;Check process_count &lt; 3 first&#xa;1. Delete existing items for this receipt&#xa;2. Set status = reprocessing&#xa;3. Re-run Textract on same S3 image&#xa;4. Re-run full matching pipeline&#xa;5. Save new items&#xa;6. Update status = completed/needs_review" vertex="1">
          <mxGeometry height="120" width="278" x="553" y="2606" as="geometry" />
        </mxCell>
        <mxCell id="s3_reprocess" parent="1" style="rounded=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;fontStyle=2;" value="Same S3 image reused&#xa;(kept 365 days for this purpose)&#xa;No extra cost for re-reading" vertex="1">
          <mxGeometry height="56" width="234" x="873" y="2622" as="geometry" />
        </mxCell>
        <mxCell id="s7_bar" parent="1" style="text;html=1;strokeColor=#4a148c;fillColor=#e1bee7;align=left;fontSize=11;fontStyle=1;fontColor=#4a148c;rounded=1;spacingLeft=8;" value="⑦ ADD NEW STORE — Admin fills in store details. Store-scoped mappings build automatically from first scan." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="2786" as="geometry" />
        </mxCell>
        <mxCell id="pwa_addstore" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;" value="Admin → &#39;Add Store&#39; screen&#xa;Fill in: store name, aliases&#xa;brand prefixes to strip&#xa;words to skip (points, savings...)" vertex="1">
          <mxGeometry height="70" width="230" x="35" y="2830" as="geometry" />
        </mxCell>
        <mxCell id="api_addstore" parent="1" style="rounded=1;fillColor=#f9a825;strokeColor=#e65100;fontSize=11;" value="POST /retailers&#xa;{retailer_id, name,&#xa; aliases, strip_prefixes,&#xa; skip_patterns}" vertex="1">
          <mxGeometry height="62" width="200" x="315" y="2834" as="geometry" />
        </mxCell>
        <mxCell id="lam_addstore" parent="1" style="rounded=1;fillColor=#8e24aa;strokeColor=#4a148c;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="⚡ reference Lambda&#xa;1. Write retailer to grocery-retailers&#xa;2. Store-scoped mappings start empty&#xa;3. First scan → global mappings used&#xa;4. Results written as store_id#key&#xa;5. Template builds itself over time" vertex="1">
          <mxGeometry height="100" width="278" x="553" y="2824" as="geometry" />
        </mxCell>
        <mxCell id="db_retailers" parent="1" style="rounded=1;fillColor=#ad1457;strokeColor=#880e4f;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="🗄️ grocery-retailers&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;PK: retailer_id&#xa;name: Tesco&#xa;aliases: [tesco express, tesco metro, tesco extra]&#xa;header_patterns: [tesco, www.tesco.com]&#xa;strip_prefixes: [tesco finest, tesco organic, tesco free from]&#xa;skip_patterns: [clubcard, points, bag for life, carrier bag]" vertex="1">
          <mxGeometry height="130" width="644" x="1153" y="2824" as="geometry" />
        </mxCell>
        <mxCell id="s8_bar" parent="1" style="text;html=1;strokeColor=#1b5e20;fillColor=#c8e6c9;align=left;fontSize=11;fontStyle=1;fontColor=#1b5e20;rounded=1;spacingLeft=8;" value="⑧ BACKUP &amp; RESTORE — Backup created automatically before every write. Restore from PWA in 30 seconds." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="3020" as="geometry" />
        </mxCell>
        <mxCell id="pwa_restore" parent="1" style="rounded=1;fillColor=#3949ab;strokeColor=#1a237e;fontColor=#fff;fontSize=10;" value="Admin → &#39;Restore Backup&#39;&#xa;Lists available backup files&#xa;User selects version&#xa;Confirms restore" vertex="1">
          <mxGeometry height="66" width="230" x="35" y="3064" as="geometry" />
        </mxCell>
        <mxCell id="api_restore" parent="1" style="rounded=1;fillColor=#f9a825;strokeColor=#e65100;fontSize=11;" value="POST /admin/restore-backup&#xa;{backup_filename}" vertex="1">
          <mxGeometry height="46" width="200" x="315" y="3076" as="geometry" />
        </mxCell>
        <mxCell id="lam_restore" parent="1" style="rounded=1;fillColor=#8e24aa;strokeColor=#4a148c;fontColor=#fff;fontSize=10;align=left;spacingLeft=6;" value="⚡ admin Lambda&#xa;1. List backup files in S3&#xa;2. Return list to PWA&#xa;3. User selects backup&#xa;4. Copy selected backup → master.xlsx&#xa;5. Power BI reads updated file on next refresh" vertex="1">
          <mxGeometry height="104" width="278" x="553" y="3058" as="geometry" />
        </mxCell>
        <mxCell id="s3_restore_note" parent="1" style="rounded=1;fillColor=#2e7d32;strokeColor=#1b5e20;fontColor=#fff;fontSize=10;" value="🪣 S3: grocery-exports&#xa;Backup files auto-created before every write&#xa;master_backup_2026-03-01.xlsx&#xa;master_backup_2026-02-28.xlsx&#xa;...kept 30 days then auto-deleted" vertex="1">
          <mxGeometry height="100" width="234" x="873" y="3064" as="geometry" />
        </mxCell>
        <mxCell id="s9_bar" parent="1" style="text;html=1;strokeColor=#e65100;fillColor=#fff3e0;align=left;fontSize=11;fontStyle=1;fontColor=#e65100;rounded=1;spacingLeft=8;" value="⚙️ COST SAFEGUARDS — Three layers prevent runaway costs: AWS billing alarm, Lambda process_count limit, daily invocation cap." vertex="1">
          <mxGeometry height="26" width="1780" x="20" y="3230" as="geometry" />
        </mxCell>
        <mxCell id="safeguard1" parent="1" style="rounded=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;" value="🛡️ Safeguard 1: AWS Billing Alarm&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Set in AWS CloudWatch (5 min setup)&#xa;Sends email when monthly bill exceeds $5&#xa;Second alarm at $10 — investigate immediately&#xa;Optional: AWS Budget can block API Gateway if $10 exceeded" vertex="1">
          <mxGeometry height="100" width="530" x="35" y="3274" as="geometry" />
        </mxCell>
        <mxCell id="safeguard2" parent="1" style="rounded=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;" value="🛡️ Safeguard 2: Per-Receipt Process Limit (in Lambda code)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;process_count field on each receipt record&#xa;Lambda checks: if process_count ≥ 3 → STOP&#xa;Set status = failed, log warning, send alert email&#xa;Prevents single receipt triggering Textract repeatedly&#xa;At £0.012/call, 3 max = £0.036 worst case per receipt" vertex="1">
          <mxGeometry height="110" width="530" x="35" y="3390" as="geometry" />
        </mxCell>
        <mxCell id="safeguard3" parent="1" style="rounded=1;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;align=left;spacingLeft=6;" value="🛡️ Safeguard 3: Lambda Reserved Concurrency Cap&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Set processor Lambda max concurrency = 2&#xa;Means max 2 receipts processing at the same time&#xa;Any extra triggers queued, not run in parallel&#xa;Prevents burst of invocations from a bug&#xa;Set in AWS Lambda → Configuration → Concurrency" vertex="1">
          <mxGeometry height="110" width="530" x="35" y="3516" as="geometry" />
        </mxCell>
